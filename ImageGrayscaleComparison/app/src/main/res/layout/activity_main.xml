<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android 图片灰度值比较演示"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:textColor="@android:color/black" />

        <!-- 图片选择按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/selectImage1Btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="选择图片1"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/selectImage2Btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="选择图片2"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- 原始图片显示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="原始图片"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="@android:color/black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imageView1"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="@android:color/darker_gray"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="@android:color/darker_gray"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- 灰度图片显示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="灰度图片"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="@android:color/black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/grayscaleView1"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="@android:color/darker_gray"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/grayscaleView2"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="@android:color/darker_gray"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- 比较按钮 -->
        <Button
            android:id="@+id/compareBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="比较灰度值"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:enabled="false" />

        <!-- 进度提示 -->
        <TextView
            android:id="@+id/progressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在处理..."
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:textColor="@android:color/holo_blue_dark" />

        <!-- 比较结果 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="比较结果"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请先选择两张图片，然后点击"比较灰度值"按钮开始比较。\n\n演示功能：\n1. 支持从相册选择图片\n2. 自动转换为灰度图像\n3. 三种比较方法：批量像素比较、逐个像素比较、直方图比较\n4. 显示详细的相似度分析结果"
            android:textSize="14sp"
            android:background="@android:color/white"
            android:padding="12dp"
            android:textColor="@android:color/black"
            android:fontFamily="monospace" />

        <!-- 说明文本 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n使用说明：\n• 批量像素比较法：使用getPixels()批量获取像素，性能最优\n• 逐个像素比较法：使用getPixel()逐个获取，性能较差但结果相同\n• 直方图比较法：分析灰度分布特征，适合整体相似度判断\n\n灰度转换公式：Gray = 0.299*R + 0.587*G + 0.114*B"
            android:textSize="12sp"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@android:color/background_light"
            android:textColor="@android:color/darker_gray" />

    </LinearLayout>

</ScrollView>